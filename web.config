<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appSettings>
    <add key="DTMIS_SMTP_HOST" value="smtp.gmail.com" />
    <add key="DTMIS_SMTP_PORT" value="465" />
    <add key="DTMIS_SMTP_USERNAME" value="kervzie3kpc@gmail.com" />
    <add key="DTMIS_SMTP_PASSWORD" value="gnpx apzz pvrb situ" />
    <add key="DTMIS_SMTP_ENCRYPTION" value="ssl" />
    <add key="DTMIS_SMTP_AUTH" value="true" />
    <add key="DTMIS_SMTP_FROM_EMAIL" value="kervzie3kpc@gmail.com" />
    <add key="DTMIS_SMTP_FROM_NAME" value="DENR Region XII DTMIS" />
  </appSettings>

  <system.webServer>
    <staticContent>
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>

    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="index.php" />
        <add value="index.html" />
        <add value="index.htm" />
      </files>
    </defaultDocument>

    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="268435456" />
      </requestFiltering>
    </security>

    <rewrite>
      <rules>
        <rule name="CanonicalAuthPhp" stopProcessing="true">
          <match url="^auth/([A-Za-z0-9_-]+)\.php$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^(GET|HEAD)$" />
          </conditions>
          <action type="Redirect" url="auth/{R:1}" appendQueryString="true" redirectType="Temporary" />
        </rule>

        <rule name="CanonicalSupportCenterPhp" stopProcessing="true">
          <match url="^support-center\.php$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^(GET|HEAD)$" />
          </conditions>
          <action type="Redirect" url="support-center" appendQueryString="true" redirectType="Temporary" />
        </rule>

        <rule name="CanonicalRootStandalonePhp" stopProcessing="true">
          <match url="^(dashboard|notifications|print-package|tracking-slip|softcopy-digital-signature|softcopy-qr-stamp|softcopy-records-unit-stamp)\.php$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^(GET|HEAD)$" />
          </conditions>
          <action type="Redirect" url="{R:1}" appendQueryString="true" redirectType="Temporary" />
        </rule>

        <rule name="CanonicalPacdoPhp" stopProcessing="true">
          <match url="^PACDO/([A-Za-z0-9_-]+)\.php$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^(GET|HEAD)$" />
          </conditions>
          <action type="Redirect" url="PACDO/{R:1}" appendQueryString="true" redirectType="Temporary" />
        </rule>

        <rule name="CanonicalRolePagePhp" stopProcessing="true">
          <match url="^(ADMIN|ARD-MS|ARD-TS|CENRO-ADMIN-RECORD|CENRO-OFFICER|CENRO-SECTION|CENRO-UNIT|DIVISION-CHIEF|ORED|PAMO-ADMIN|PASU-OFFICER|PAMO-UNIT|RECORS-UNIT|PENRO-ADMIN-RECORD|PENRO-DIVISION|PENRO-OFFICER|PENRO-SECTION|PENRO-SECTION-UNIT|SECTION-STAFF|SUPER-ADMIN)/([A-Za-z0-9_-]+)\.php$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^(GET|HEAD)$" />
          </conditions>
          <action type="Redirect" url="{R:1}/{R:2}" appendQueryString="true" redirectType="Temporary" />
        </rule>

        <rule name="AuthShortcut" stopProcessing="true">
          <match url="^auth/?$" ignoreCase="true" />
          <action type="Rewrite" url="auth/login.php" appendQueryString="true" />
        </rule>

        <rule name="AuthCleanRoutes" stopProcessing="true">
          <match url="^auth/([A-Za-z0-9_-]+)/?$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="auth/{R:1}.php" appendQueryString="true" />
        </rule>

        <rule name="SupportCenterCleanRoute" stopProcessing="true">
          <match url="^support-center/?$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="support-center.php" appendQueryString="true" />
        </rule>

        <rule name="LegacyRootFiles" stopProcessing="true">
          <match url="^(check_qa\.php|verify_final\.php)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="root-files/{R:1}" appendQueryString="true" />
        </rule>

        <rule name="RootStandalonePagesClean" stopProcessing="true">
          <match url="^(dashboard|notifications|print-package|tracking-slip|softcopy-digital-signature|softcopy-qr-stamp|softcopy-records-unit-stamp)/?$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="app/pages/{R:1}.php" appendQueryString="true" />
        </rule>

        <rule name="RootStandalonePages" stopProcessing="true">
          <match url="^(dashboard|notifications|print-package|tracking-slip|softcopy-digital-signature|softcopy-qr-stamp|softcopy-records-unit-stamp)\.php$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="app/pages/{R:1}.php" appendQueryString="true" />
        </rule>

        <rule name="RootDashboardCss" stopProcessing="true">
          <match url="^dashboard\.css$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="assets/css/dashboard.css" appendQueryString="true" />
        </rule>

        <rule name="RootNotifSound" stopProcessing="true">
          <match url="^notif-sound\.wav$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="assets/audio/notif-sound.wav" appendQueryString="true" />
        </rule>

        <rule name="RootFavicon" stopProcessing="true">
          <match url="^favicon\.ico$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="assets/Logo.png" appendQueryString="false" />
        </rule>

        <rule name="LegacyActions" stopProcessing="true">
          <match url="^actions/([A-Za-z0-9._-]+\.php)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="app/actions/{R:1}" appendQueryString="true" />
        </rule>

        <rule name="LegacyModules" stopProcessing="true">
          <match url="^modules/([A-Za-z0-9._-]+\.php)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="app/modules/{R:1}" appendQueryString="true" />
        </rule>

        <rule name="RolePageTemplate" stopProcessing="true">
          <match url="^role-page-template\.php$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="app/templates/role-page-template.php" appendQueryString="true" />
        </rule>

        <rule name="PacdoPages" stopProcessing="true">
          <match url="^PACDO/pages/([A-Za-z0-9._-]+\.php)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/RECORS-UNIT/pages/{R:1}" appendQueryString="true" />
        </rule>

        <rule name="PacdoAssets" stopProcessing="true">
          <match url="^PACDO/assets/(.+)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/RECORS-UNIT/assets/{R:1}" appendQueryString="true" />
        </rule>

        <rule name="PacdoPartials" stopProcessing="true">
          <match url="^PACDO/partials/(.+)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/RECORS-UNIT/partials/{R:1}" appendQueryString="true" />
        </rule>

        <rule name="PacdoCss" stopProcessing="true">
          <match url="^PACDO/css/(.+\.css)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/RECORS-UNIT/assets/css/{R:1}" appendQueryString="true" />
        </rule>

        <rule name="PacdoLegacyPages" stopProcessing="true">
          <match url="^PACDO/([A-Za-z0-9._-]+\.php)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/RECORS-UNIT/pages/{R:1}" appendQueryString="true" />
        </rule>

        <rule name="PacdoCleanPages" stopProcessing="true">
          <match url="^PACDO/([A-Za-z0-9_-]+)/?$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/RECORS-UNIT/pages/{R:1}.php" appendQueryString="true" />
        </rule>

        <rule name="RoleCleanPages" stopProcessing="true">
          <match url="^(ADMIN|ARD-MS|ARD-TS|CENRO-ADMIN-RECORD|CENRO-OFFICER|CENRO-SECTION|CENRO-UNIT|DIVISION-CHIEF|ORED|PAMO-ADMIN|PASU-OFFICER|PAMO-UNIT|RECORS-UNIT|PENRO-ADMIN-RECORD|PENRO-DIVISION|PENRO-OFFICER|PENRO-SECTION|PENRO-SECTION-UNIT|SECTION-STAFF|SUPER-ADMIN)/([A-Za-z0-9_-]+)/?$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/{R:1}/pages/{R:2}.php" appendQueryString="true" />
        </rule>

        <rule name="RolePagesFolder" stopProcessing="true">
          <match url="^(ADMIN|ARD-MS|ARD-TS|CENRO-ADMIN-RECORD|CENRO-OFFICER|CENRO-SECTION|CENRO-UNIT|DIVISION-CHIEF|ORED|PAMO-ADMIN|PASU-OFFICER|PAMO-UNIT|RECORS-UNIT|PENRO-ADMIN-RECORD|PENRO-DIVISION|PENRO-OFFICER|PENRO-SECTION|PENRO-SECTION-UNIT|SECTION-STAFF|SUPER-ADMIN)/pages/([A-Za-z0-9._-]+\.php)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/{R:1}/pages/{R:2}" appendQueryString="true" />
        </rule>

        <rule name="RoleAssetsFolder" stopProcessing="true">
          <match url="^(ADMIN|ARD-MS|ARD-TS|CENRO-ADMIN-RECORD|CENRO-OFFICER|CENRO-SECTION|CENRO-UNIT|DIVISION-CHIEF|ORED|PAMO-ADMIN|PASU-OFFICER|PAMO-UNIT|RECORS-UNIT|PENRO-ADMIN-RECORD|PENRO-DIVISION|PENRO-OFFICER|PENRO-SECTION|PENRO-SECTION-UNIT|SECTION-STAFF|SUPER-ADMIN)/assets/(.+)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/{R:1}/assets/{R:2}" appendQueryString="true" />
        </rule>

        <rule name="RolePartialsFolder" stopProcessing="true">
          <match url="^(ADMIN|ARD-MS|ARD-TS|CENRO-ADMIN-RECORD|CENRO-OFFICER|CENRO-SECTION|CENRO-UNIT|DIVISION-CHIEF|ORED|PAMO-ADMIN|PASU-OFFICER|PAMO-UNIT|RECORS-UNIT|PENRO-ADMIN-RECORD|PENRO-DIVISION|PENRO-OFFICER|PENRO-SECTION|PENRO-SECTION-UNIT|SECTION-STAFF|SUPER-ADMIN)/partials/(.+)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/{R:1}/partials/{R:2}" appendQueryString="true" />
        </rule>

        <rule name="RoleCssLegacy" stopProcessing="true">
          <match url="^(ADMIN|ARD-MS|ARD-TS|CENRO-ADMIN-RECORD|CENRO-OFFICER|CENRO-SECTION|CENRO-UNIT|DIVISION-CHIEF|ORED|PAMO-ADMIN|PASU-OFFICER|PAMO-UNIT|RECORS-UNIT|PENRO-ADMIN-RECORD|PENRO-DIVISION|PENRO-OFFICER|PENRO-SECTION|PENRO-SECTION-UNIT|SECTION-STAFF|SUPER-ADMIN)/css/(.+\.css)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/{R:1}/assets/css/{R:2}" appendQueryString="true" />
        </rule>

        <rule name="RoleLegacyPages" stopProcessing="true">
          <match url="^(ADMIN|ARD-MS|ARD-TS|CENRO-ADMIN-RECORD|CENRO-OFFICER|CENRO-SECTION|CENRO-UNIT|DIVISION-CHIEF|ORED|PAMO-ADMIN|PASU-OFFICER|PAMO-UNIT|RECORS-UNIT|PENRO-ADMIN-RECORD|PENRO-DIVISION|PENRO-OFFICER|PENRO-SECTION|PENRO-SECTION-UNIT|SECTION-STAFF|SUPER-ADMIN)/([A-Za-z0-9._-]+\.php)$" ignoreCase="true" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="roles/{R:1}/pages/{R:2}" appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>

  <location path="service-worker.js">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <location path="manifest.webmanifest">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>
